option_settings:
  aws:elasticbeanstalk:container:php:phpini:
    document_root: /public
    memory_limit: 256M
  aws:elasticbeanstalk:application:environment:
    COMPOSER_HOME: /tmp/.composer
    VIEW_COMPILED_PATH: /tmp/views
    LOG_CHANNEL: stderr
    SESSION_DRIVER: file
    CACHE_STORE: file

files:
  "/etc/php.d/99-laravel.ini":
    mode: "000644"
    owner: root
    group: root
    content: |
      sys_temp_dir=/tmp
      upload_tmp_dir=/tmp

container_commands:
  01_dirs:
    command: "mkdir -p storage/framework/sessions storage/framework/views storage/framework/cache storage/logs bootstrap/cache /tmp/views"
  02_perms:
    command: "chmod -R 777 storage bootstrap/cache /tmp/views"
  03_sqlite:
    command: "touch database/database.sqlite && chmod 666 database/database.sqlite"
  04_tmp:
    command: "chmod 1777 /tmp"
